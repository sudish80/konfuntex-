# LLM Provider
COLAB_AGENT_LLM_PROVIDER=openai
COLAB_AGENT_LLM_MODEL=gpt-4
COLAB_AGENT_OPENAI_API_KEY=
# COLAB_AGENT_OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1

# HuggingFace
COLAB_AGENT_HF_TOKEN=

# GitHub
COLAB_AGENT_GITHUB_TOKEN=
COLAB_AGENT_GITHUB_REPO=

# Fine-tuning defaults
COLAB_AGENT_DEFAULT_FINETUNE_METHOD=qlora
COLAB_AGENT_DEFAULT_BASE_MODEL=microsoft/phi-2

# Agent
COLAB_AGENT_AGENT_VERBOSE=true
